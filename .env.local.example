# AQUAPURE — variables d'environnement (exemple)
# Copiez ce fichier en `.env.local` et renseignez les vraies valeurs.
# NE COMMITEZ JAMAIS de valeurs réelles. `.env.local` est gitignoré.

# ── Supabase ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Emails (Resend) ─────────────────────────────────────────────────────────
RESEND_API_KEY=
DEVIS_NOTIFICATION_EMAIL=

# ── SEO ─────────────────────────────────────────────────────────────────────
# Laisser vide/false tant que le site est en preview (anti-duplicate content).
NEXT_PUBLIC_ALLOW_INDEXING=false

# ── Admin (étape 6a) ────────────────────────────────────────────────────────
# Mot de passe unique de l'espace /admin (un seul admin : Mehdi).
ADMIN_PASSWORD=
# Secret aléatoire pour signer le cookie de session (HMAC-SHA256).
# Générer p.ex. avec :  openssl rand -hex 32
ADMIN_SESSION_SECRET=

# ── Embeddings (6d) + génération d'images (dev) ─────────────────────────────
# Serveur only. Embeddings de la base de connaissances (text-embedding-3-small).
OPENAI_API_KEY=

# ── Chatbot « Aqua » (étape 6e) ─────────────────────────────────────────────
# Clé API Anthropic pour la génération des réponses (claude-haiku-4-5). Serveur only.
ANTHROPIC_API_KEY=
